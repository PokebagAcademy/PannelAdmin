################################################################
#  Cobblepanel — PRODUCTION .env
#  Copy to .env on the VPS (next to docker-compose.prod.yml)
#  Never commit this file with real secrets.
################################################################

# --- App ---
NODE_ENV=production
# Public URL — MUST be HTTPS in production, exactly the domain users hit.
# No trailing slash.
NEXTAUTH_URL=https://YOUR-DOMAIN.duckdns.org

# Auth.js session secret. Generate with: openssl rand -base64 32
AUTH_SECRET=

# --- Database ---
# Pick a strong random password (it's only used internally between containers).
POSTGRES_USER=cobble
POSTGRES_PASSWORD=
POSTGRES_DB=cobblepanel

# --- GitHub OAuth (user login) ---
# In your dev GitHub OAuth App, add this callback URL alongside the dev one:
#   https://YOUR-DOMAIN.duckdns.org/api/auth/callback/github
# Use the SAME client id/secret as dev.
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
ALLOWED_GITHUB_ORG=

# --- GitHub App (repo creation & writes) ---
# In your dev GitHub App, ADD to the existing URLs:
#   Callback URL:  https://YOUR-DOMAIN.duckdns.org/api/github/app/install
#   Setup URL:     https://YOUR-DOMAIN.duckdns.org/api/github/app/install
# Reinstall the App on your org once URLs are updated.
GITHUB_APP_ID=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
# Same private key as dev (single line with \n escapes).
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_SLUG=

# --- Encryption ---
# CRITICAL: must be the SAME as dev if you want to migrate the DB.
# Or a NEW value (64 hex chars) if starting fresh in prod.
# Generate fresh:  openssl rand -hex 32
ENCRYPTION_KEY=
