# --- App ---
NODE_ENV=development
NEXTAUTH_URL=http://localhost:3000
# openssl rand -base64 32
AUTH_SECRET=changeme_run_openssl_rand_base64_32

# --- Database ---
POSTGRES_USER=cobble
POSTGRES_PASSWORD=changeme
POSTGRES_DB=cobblepanel
DATABASE_URL=postgresql://cobble:changeme@localhost:5432/cobblepanel

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- GitHub OAuth (user login) — see Phase 1 docs ---
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
ALLOWED_GITHUB_ORG=

# --- GitHub App (Phase 3 — for repo creation & automated actions) ---
# Create at: https://github.com/organizations/<ORG>/settings/apps/new
GITHUB_APP_ID=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
# Private key downloaded from GitHub. Paste as a single line with \n escapes:
#   awk 'NF {printf "%s\\n", $0}' your-app.private-key.pem
GITHUB_APP_PRIVATE_KEY=
# Slug of the GitHub App (the URL fragment, e.g. "cobblepanel-prod"). Used
# only to build the one-click install link in /settings/github.
GITHUB_APP_SLUG=

# --- Encryption (SSH keys + Anthropic API keys storage) ---
# openssl rand -hex 32 (must be 64 hex chars = 32 bytes)
ENCRYPTION_KEY=changeme_run_openssl_rand_hex_32
